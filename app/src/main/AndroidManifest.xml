<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/AndroidManifest.xml — REEMPLAZA el archivo actual -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA"/>

    <application
        android:name=".AdminiumsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Adminiums1">

        <activity
            android:name=".ui.auth.RolSelectorActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".ui.auth.RegistroActivity"  android:exported="false"/>
        <activity android:name=".ui.auth.LoginActivity"     android:exported="false"/>

        <activity android:name=".ui.residente.ResidenteActivity"        android:exported="false"/>
        <activity android:name=".ui.residente.GenerarQRActivity"        android:exported="false"/>
        <activity android:name=".ui.residente.ReservarAmenidadActivity" android:exported="false"/>
        <activity android:name=".ui.residente.PagarCuotaActivity"       android:exported="false"/>

        <activity android:name=".ui.vigilante.VigilanteActivity"        android:exported="false"/>

        <activity android:name=".ui.admin.AdminActivity"                android:exported="false"/>

        <activity android:name=".MainActivity"                          android:exported="false"/>
    </application>
</manifest>
