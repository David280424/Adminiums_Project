<?xml version="1.0" encoding="utf-8"?>
<!-- item_reservacion_detalle.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="10dp"
    android:gravity="center_vertical"
    android:background="@color/gray_light"
    android:layout_marginBottom="6dp">

    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
        android:text="📅" android:textSize="18sp" android:layout_marginEnd="10dp"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvResAmenidad"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textStyle="bold" android:textColor="@color/colorPrimary"/>
        <TextView android:id="@+id/tvResFecha"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/colorTextSecondary"/>
    </LinearLayout>
</LinearLayout>
