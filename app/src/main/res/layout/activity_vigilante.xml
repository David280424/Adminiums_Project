<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_vigilante">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="Control de Acceso"
                app:titleTextColor="@color/white"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvNombreVigilante"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Vigilante" android:textSize="11sp" android:textColor="#B3FFFFFF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Button android:id="@+id/btnLogout"
                    android:layout_width="wrap_content" android:layout_height="32dp"
                    android:text="Salir" android:textSize="11sp" android:textColor="@color/white"
                    android:backgroundTint="#26FFFFFF"
                    style="@style/Widget.MaterialComponents.Button"
                    app:strokeColor="#4DFFFFFF" app:strokeWidth="1dp" app:cornerRadius="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <Button android:id="@+id/btnTabManual"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:text="Manual" android:textSize="11sp" android:textColor="@color/white"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:paddingBottom="0dp"/>

                <Button android:id="@+id/btnTabQR"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:text="Escanear QR" android:textSize="11sp" android:textColor="#99FFFFFF"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:paddingBottom="0dp"/>

                <Button android:id="@+id/btnTabHistorial"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:text="Historial" android:textSize="11sp" android:textColor="#99FFFFFF"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:paddingBottom="0dp"/>
            </LinearLayout>

            <View
                android:id="@+id/tabIndicator"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:background="@color/colorGreen"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TAB 1: MANUAL -->
            <LinearLayout android:id="@+id/layoutManual"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card_border"
                    android:padding="14dp" android:layout_marginBottom="14dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Accesos de hoy" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/colorTextSecondary" android:layout_marginBottom="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tvAccesosResidentes"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Residentes" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tvAccesosVisitantes"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Visitantes" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tvAccesosPendientes"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/colorAmber"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pendientes" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Buscar residente" android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary" android:layout_marginBottom="5dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <EditText android:id="@+id/etBuscarManual"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_field"
                        android:hint="Nombre o unidad..."
                        android:paddingHorizontal="12dp" android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary" android:textColorHint="@color/colorTextTertiary"
                        android:inputType="text" android:imeOptions="actionSearch"/>

                    <Button
                        android:id="@+id/btnBuscarManual"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="Buscar"
                        android:textSize="11sp"
                        app:cornerRadius="8dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cardConfirmarManual"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card_border"
                    android:padding="14dp" android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <TextView android:id="@+id/tvResidenteEncontradoNombre"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nombre" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"/>
                    <TextView android:id="@+id/tvResidenteEncontradoUnidad"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Unidad" android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="2dp" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnConfirmarEntrada"
                            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                            android:layout_marginEnd="6dp" android:text="Confirmar entrada" android:textSize="12sp"
                            app:backgroundTint="@color/colorPrimary" android:textColor="@color/white"
                            app:cornerRadius="8dp"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnCancelarManual"
                            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                            android:layout_marginStart="6dp" android:text="Cancelar" android:textSize="12sp"
                            app:backgroundTint="@color/colorSurfaceSecondary" android:textColor="@color/colorTextPrimary"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:id="@+id/layoutAccesoSuccess"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_badge_green" android:padding="12dp"
                    android:layout_marginBottom="12dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ Acceso registrado correctamente" android:textSize="12sp"
                        android:textColor="@color/colorSuccess"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Registrar visitante externo" android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="4dp" android:layout_marginBottom="5dp"/>

                <EditText android:id="@+id/etNombreVisitante"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Nombre del visitante..." android:paddingHorizontal="12dp"
                    android:textSize="13sp" android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:inputType="textPersonName" android:layout_marginBottom="8dp"/>

                <EditText android:id="@+id/etVisitaAUnidad"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Visita a unidad..." android:paddingHorizontal="12dp"
                    android:textSize="13sp" android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:inputType="text" android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnRegistrarVisitante"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="Registrar ingreso" android:textSize="13sp"
                    app:backgroundTint="@color/colorPrimary" android:textColor="@color/white"
                    app:cornerRadius="8dp"/>

                <ProgressBar android:id="@+id/progressManual"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:layout_marginTop="8dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- TAB 2: QR -->
            <LinearLayout android:id="@+id/layoutQR"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp"
                android:gravity="center_horizontal" android:visibility="gone">

                <FrameLayout
                    android:layout_width="180dp" android:layout_height="180dp"
                    android:background="@drawable/bg_qr_box" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="📷" android:textSize="48sp"/>
                </FrameLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Apunta la cámara al QR del residente o visitante para registrar su entrada automáticamente"
                    android:textSize="12sp" android:textColor="@color/colorTextSecondary"
                    android:gravity="center" android:layout_marginBottom="20dp"/>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnEscanearQR"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:text="Activar escáner QR" android:textSize="14sp" android:textStyle="bold"
                    app:backgroundTint="@color/colorVigilante" android:textColor="@color/white"
                    app:cornerRadius="10dp" android:layout_marginBottom="16dp"/>

                <ProgressBar android:id="@+id/progressQR"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:visibility="gone" android:layout_marginBottom="8dp"/>

                <LinearLayout android:id="@+id/layoutQrResult"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_badge_green"
                    android:padding="14dp" android:gravity="center" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="QR válido" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorSuccess"/>
                    <TextView android:id="@+id/tvResultadoQR"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="" android:textSize="12sp" android:textColor="@color/colorSuccess"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- TAB 3: HISTORIAL -->
            <LinearLayout android:id="@+id/layoutHistorial"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <HorizontalScrollView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:paddingTop="12dp" android:paddingBottom="10dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:id="@+id/tvFechaHistorial"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="10dp" android:textSize="12sp"
                            android:textColor="@color/colorTextPrimary" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tvTotalEntradas"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:gravity="center_vertical" android:text="0 entradas"
                            android:textSize="12sp" android:textColor="@color/colorTextSecondary"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <ProgressBar android:id="@+id/progressHistorial"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <TextView android:id="@+id/tvSinAccesos"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:text="Sin registros por ahora"
                    android:textSize="13sp" android:textColor="@color/colorTextSecondary"
                    android:padding="20dp" android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvHistorial"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="16dp"
                    android:nestedScrollingEnabled="false" android:clipToPadding="false"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
