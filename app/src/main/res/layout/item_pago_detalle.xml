<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="10dp"
    android:gravity="center_vertical"
    android:background="@color/colorSurfaceSecondary"
    android:layout_marginBottom="6dp">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvPagoMonto"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="16sp" android:textStyle="bold" android:textColor="@color/colorTextPrimary"/>
        <TextView android:id="@+id/tvPagoFecha"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/colorTextSecondary"/>
    </LinearLayout>

    <TextView android:id="@+id/tvPagoEstado"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Pagado" android:textSize="11sp" android:textStyle="bold"
        android:textColor="@color/white"
        android:paddingHorizontal="10dp" android:paddingVertical="4dp"/>
</LinearLayout>
