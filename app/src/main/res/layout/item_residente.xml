<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card_border">

    <TextView
        android:id="@+id/tvResidenteAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/colorAvatarBlueText"
        android:background="@drawable/bg_avatar_blue"
        android:layout_marginEnd="10dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvResidenteNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Residente"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"/>

        <TextView
            android:id="@+id/tvResidenteUnidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unidad 101"
            android:textSize="11sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="1dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvResidenteEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Al día"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/colorSuccess"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:background="@drawable/bg_badge_green"/>

</LinearLayout>
