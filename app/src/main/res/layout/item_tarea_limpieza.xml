<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/viewPrioridad"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/colorTextTertiary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvAreaIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_avatar_blue"
                android:gravity="center"
                android:text="🏠"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAreaNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Área"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTipoLimpieza"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvAsignadaA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin asignar"
                    android:textColor="@color/colorError"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvSolicitadaPor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicitado por: --"
                    android:textColor="@color/colorTextTertiary"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFechaLimite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textSize="10sp"
                app:chipMinTouchTargetSize="0dp" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
